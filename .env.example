# Production environment for compose/docker-compose.prod.yml
# Copy on the VPS:
#   cp .env.example .env
#   cp .env compose/.env
# Never commit real .env files.

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=aifa
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=aifa_ecommerce
POSTGRES_LOCAL_PORT=5432

# ── Public URL (single domain for storefront + API) ──────────────
NEXT_PUBLIC_APP_URL=https://aifascentique.shop
NEXT_PUBLIC_API_URL=https://aifascentique.shop

# Frontend display name (optional)
# NEXT_PUBLIC_STORE_NAME=AIFA SCENTIQUE

# ── Auth (min 32 chars each; openssl rand -hex 32) ───────────────
JWT_SECRET=
JWT_ADMIN_SECRET=
JWT_CUSTOMER_SECRET=

# ── Backend (email verification links, invoices) ─────────────────
VERIFY_EMAIL_BASE_URL=https://aifascentique.shop

# ── Cloudinary (optional — admin image uploads) ──────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── SMTP (optional — real order emails) ──────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=AIFA SCENTIQUE <noreply@aifascentique.shop>

# ── Razorpay ─────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── Optional image tags (registry instead of local build) ────────
# API_IMAGE=aifa-ecommerce-api:latest
# WEB_IMAGE=aifa-ecommerce-web:latest
